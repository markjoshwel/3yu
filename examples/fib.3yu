; fib~ :: Function(Integer) -> Integer
d fib~ FII
: fib~ (
   ; argument declaration
   d n~ I   : n~ $1

   ; base case
   = n~ 0           ; n~ = n~ == 0
   ? n~ ( ` 0 ` )   ; if n~ is not 0, return 0

   = n~ 1           ; n~ = n~ == 1
   ? n~ ( ` 1 ` )   ; if n~ is not 1, return 1

   ; recursive case
   d left~ I
   - n~    1
   @ fib~  $0
   : left~ $0

   d right~ I
   - n~     2
   @ fib~   $0
   : right~ $0

   + left~ right~
   ` $0 `
)

@ stdout~ ( @ fib~ 32 )
